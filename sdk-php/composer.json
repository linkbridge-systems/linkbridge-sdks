{
    "name": "linkbridge/sdk-php",
    "description": "PHP SDK for the Linkbridge SI + APP e-invoicing API.",
    "type": "library",
    "license": "Apache-2.0",
    "homepage": "https://docs.linkbridge.ng",
    "support": {
        "source": "https://github.com/linkbridge-systems/sdk-php",
        "issues": "https://github.com/linkbridge-systems/sdk-php/issues",
        "docs": "https://docs.linkbridge.ng"
    },
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-hash": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Linkbridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Linkbridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
