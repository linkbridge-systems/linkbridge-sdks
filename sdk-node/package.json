{
  "name": "@linkbridge/sdk",
  "version": "0.4.0",
  "description": "Official Node.js / TypeScript SDK for the Linkbridge e-invoicing API.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "import": "./dist/webhook.js"
    },
    "./oapi": {
      "types": "./dist/oapi/schema.gen.d.ts",
      "import": "./dist/oapi/schema.gen.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linkbridge-systems/linkbridge-sdks.git",
    "directory": "sdk-node"
  },
  "homepage": "https://docs.linkbridge.ng",
  "bugs": "https://github.com/linkbridge-systems/linkbridge-sdks/issues",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "tsc -p tsconfig.json --noEmit",
    "codegen": "openapi-typescript ../../tools/openapi/openapi.yaml -o src/oapi/schema.gen.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.10",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@redocly/openapi-core": "^1.34.17",
    "js-yaml": "^4.2.0"
  }
}
